rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // IDENTITY VERIFICATION RULES
    match /verificationRequests/{requestId} {
      // Allow users to create their own request and read it back
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      // Only admins can update status or delete
      allow update, delete: if isAdmin();
    }

    match /blockchainProofs/{proofId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Bookings collection rules
    match /bookings/{bookingId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.customerId || 
        request.auth.uid == resource.data.kuliId || 
        isAdmin()
      );
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.customerId || 
        request.auth.uid == resource.data.kuliId || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Admin Specific Collections
    match /admin_config/{document=**} {
      allow read, write: if isAdmin();
    }

    // Analytics / Payments
    match /analytics/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
